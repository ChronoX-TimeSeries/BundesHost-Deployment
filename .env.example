POSTGRES_DB=bundeshost
POSTGRES_USER=bundeshost
POSTGRES_PASSWORD=bundeshost
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# MLflow + DagsHub
# URI is the same for all team members (don't change)
MLFLOW_TRACKING_URI=https://dagshub.com/ChronoX-TimeSeries/BundesHost-Deployment.mlflow
# Your DagsHub username (e.g. nazila-tourism)
MLFLOW_TRACKING_USERNAME=
# Your DagsHub Personal Access Token from https://dagshub.com/user/settings/tokens
MLFLOW_TRACKING_PASSWORD=

# Destatis GENESIS-Online API (Phase E)
# Get a token from GENESIS-Online: Webservice-Schnittstelle (API) → Generate token
DESTATIS_API_BASE_URL=https://genesis.destatis.de/genesisWS/rest/2020/
DESTATIS_API_TOKEN=your_token_here

# Prefect Cloud
PREFECT_API_URL=https://api.prefect.cloud/api/accounts/<your-account-id>/workspaces/<your-workspace-id>
PREFECT_API_KEY=<your-prefect-pat>

# Phase F+ — Supabase (cloud Postgres for cloud deploy)
SUPABASE_POSTGRES_HOST=aws-N-eu-central-1.pooler.supabase.com
SUPABASE_POSTGRES_PORT=5432
SUPABASE_POSTGRES_DB=postgres
SUPABASE_POSTGRES_USER=postgres.<your-project-ref>
SUPABASE_POSTGRES_PASSWORD=<your-supabase-db-password>

# Phase H — Admin API auth
# Shared secret for the protected /admin/clear-cache endpoint.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=
