{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "BundesHost API",
  "uid": "bundeshost-api",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s by handler)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_requests_total[5m]))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "p95 latency (seconds by handler)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "5xx error rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum (rate(http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total requests",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum (http_requests_total)",
          "legendFormat": "total"
        }
      ]
    }
  ]
}
